# ─── Gituas env template ─────────────────────────────────────────────────────
# Copy to .env and fill in real values. .env is gitignored.

# Database (required) — Neon / any Postgres
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Auth.js (required) — generate with: openssl rand -base64 36
AUTH_SECRET=""

# GitHub OAuth (required to sign in) — github.com/settings/developers
# Callback URL: http(s)://<host>/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Vault — 64 hex chars (32 bytes). Generate with: openssl rand -hex 32
VAULT_KEY=""

# AI providers — Gemini is the active brain; others optional
GOOGLE_AI_API_KEY=""
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NODE_ENV="development"

# Cron — Bearer token for /api/cron/run-agents
CRON_SECRET=""

# ─── Platform integrations (add after you get dev access + verify business) ───
# Register each app's callback as: <NEXT_PUBLIC_APP_URL>/api/oauth/<provider>/callback
X_CLIENT_ID=""
X_CLIENT_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
REDDIT_USER_AGENT="gituas/0.9.4 by your-handle"
# TikTok — Login Kit + Content Posting API. developers.tiktok.com
# Callback / redirect URI: <NEXT_PUBLIC_APP_URL>/api/oauth/tiktok/callback
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# Payments / infra (manual API keys via the Integrations admin, or here)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
BLOB_READ_WRITE_TOKEN=""
